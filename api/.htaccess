# Bloqueia acesso HTTP direto ao arquivo de senhas (se estiver nesta pasta)
<Files "credentials.php">
  Require all denied
</Files>

# HostGator Apache 2.2 (fallback)
<Files "credentials.php">
  Order allow,deny
  Deny from all
</Files>

# Bloqueia exemplos, SQLs e endpoints temporários (não devem ficar acessíveis publicamente)
<FilesMatch "(credentials\.example\.php|.*\.sql|debug_.*\.php|reset.*\.sql)">
  Require all denied
</FilesMatch>

<FilesMatch "(credentials\.example\.php|.*\.sql|debug_.*\.php|reset.*\.sql)">
  Order allow,deny
  Deny from all
</FilesMatch>

<IfModule mod_headers.c>
  Header always set X-Content-Type-Options "nosniff"
  Header always set X-Frame-Options "SAMEORIGIN"
</IfModule>
