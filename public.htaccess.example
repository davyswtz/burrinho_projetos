# Conteúdo espelhado em `.htaccess` na raiz do repositório.
# No servidor: coloque na raiz do site (public_html ou pasta do app).

DirectoryIndex index.html index.php
AddDefaultCharset utf-8

# Opcional: forçar HTTPS (descomente após SSL ativo no cPanel)
# RewriteEngine On
# RewriteCond %{HTTPS} !=on
# RewriteRule ^ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]
