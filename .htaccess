# Burrinho Projetos — coloque na raiz do site na HostGator (public_html)
# ou na raiz da pasta do app (ex.: public_html/burrinho/).

DirectoryIndex index.html index.php

AddDefaultCharset utf-8

# ── Segurança básica (HostGator / Apache) ───────────────────────────────────
# (Se algum header não for suportado pelo plano/versão, o Apache pode ignorar.)
<IfModule mod_headers.c>
  Header always set X-Content-Type-Options "nosniff"
  Header always set X-Frame-Options "SAMEORIGIN"
  Header always set Referrer-Policy "strict-origin-when-cross-origin"
  Header always set Permissions-Policy "geolocation=(), microphone=(), camera=()"
  # CSP mínima com Leaflet/CARTO para o mapa gratuito do dashboard.
  Header always set Content-Security-Policy "default-src 'self'; img-src 'self' data: https:; style-src 'self' 'unsafe-inline' https://unpkg.com https://cdn.jsdelivr.net; script-src 'self' 'unsafe-inline' https://unpkg.com https://cdn.jsdelivr.net; connect-src 'self' https:; frame-ancestors 'self'"
</IfModule>

# Não expor arquivos sensíveis por engano
<FilesMatch "(^\.env$|credentials\.php$|credentials\.example\.php$|.*\.sql$|debug_.*\.php$|reset.*\.sql$|DEPLOY_HOSTGATOR\.txt$|NAO_SUBIR_JS_NA_HOSTGATOR\.txt$)">
  Require all denied
</FilesMatch>

# Após SSL ativo no cPanel, descomente para forçar HTTPS:
# RewriteEngine On
# RewriteCond %{HTTPS} !=on
# RewriteRule ^ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]
